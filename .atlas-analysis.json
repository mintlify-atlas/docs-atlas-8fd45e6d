  "keyFeatures": [
    "Global transparent proxy for all Android traffic via iptables NAT",
    "VPN-based proxy mode (no root required) using tun2socks",
    "Supports HTTP, SOCKS4, and SOCKS5 proxy protocols",
    "PAC (Proxy Auto-Configuration) script support",
    "NTLM and Basic authentication for enterprise proxies",
    "Per-app proxy selection or bypass via AppManager",
    "IP/CIDR bypass list with preset configurations",
    "Auto-connect based on Wi-Fi SSID",
    "Multiple named proxy profiles",
    "Home screen widget for quick toggle"
  ],
  "publicApiSurface": [
    "ProxyDroid (main PreferenceActivity)",
    "ProxyDroidService (iptables-based proxy service)",
    "ProxyDroidVpnService (VPN-based proxy service)",
    "AppManager (per-app proxy selection)",
    "BypassListActivity (IP bypass list editor)",
    "Profile (proxy configuration data model)",
    "Profile.validateAddr(addr)",
    "Profile.encodeAddrs(addrs)",
    "Profile.decodeAddrs(encoded)",
    "Utils.runRootCommand(command)",
    "Utils.checkRoot()",
    "Utils.getIptablesPath()",
    "LocalProxyServer (HTTP-to-SOCKS5 bridge for VPN mode)",
    "Tun2SocksHelper (native tun2socks bridge)",
    "Constraints.PRESETS (built-in bypass address presets)"
  ]
